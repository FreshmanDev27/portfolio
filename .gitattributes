<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portfolio</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Segoe UI,sans-serif;
    background:#0f172a;
    color:white;
}

header{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    background:linear-gradient(135deg,#2563eb,#7c3aed);
}

.hero h1{
    font-size:4rem;
}

.hero p{
    margin-top:10px;
    font-size:1.2rem;
    opacity:.9;
}

.btn{
    display:inline-block;
    margin-top:20px;
    padding:12px 28px;
    background:white;
    color:#111;
    text-decoration:none;
    border-radius:50px;
    font-weight:bold;
}

section{
    padding:80px 10%;
}

h2{
    margin-bottom:20px;
    font-size:2rem;
}

.about{
    max-width:700px;
}

.projects{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:#1e293b;
    padding:25px;
    border-radius:20px;
    transition:.3s;
}

.card:hover{
    transform:translateY(-10px);
}

footer{
    text-align:center;
    padding:30px;
    background:#020617;
}
</style>
</head>

<body>

<header>
    <div class="hero">
        <h1>Your Name</h1>
        <p>Student • Programmer • Designer</p>
        <a href="#about" class="btn">Explore</a>
    </div>
</header>

<section id="about">
    <h2>About Me</h2>
    <div class="about">
        <p>
            I'm a student passionate about technology, coding,
            problem solving, and creating digital experiences.
        </p>
    </div>
</section>

<section>
    <h2>Skills</h2>
    <div class="projects">
        <div class="card">HTML</div>
        <div class="card">CSS</div>
        <div class="card">JavaScript</div>
        <div class="card">UI Design</div>
    </div>
</section>

<section>
    <h2>Projects</h2>
    <div class="projects">
        <div class="card">
            <h3>Portfolio Website</h3>
            <p>Responsive personal portfolio.</p>
        </div>

        <div class="card">
            <h3>Calculator App</h3>
            <p>Simple calculator using JavaScript.</p>
        </div>

        <div class="card">
            <h3>School Project</h3>
            <p>Academic web project.</p>
        </div>
    </div>
</section>

<section>
    <h2>Contact</h2>
    <p>Email: your@email.com</p>
</section>

<footer>
    © 2026 Your Name
</footer>

</body>
</html>
